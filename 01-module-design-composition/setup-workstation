#!/bin/bash
set -euxo pipefail

# Challenge 1 Setup: Module Design & Composition
# Clone assets from GitHub and prepare environment

echo "=== Challenge 1: Module Design & Composition Setup ==="

# Navigate to workspace
cd /root/terraform-workspace

# Clean any existing content
rm -rf *

# Clone the lab assets repository
echo "Cloning lab assets from GitHub..."
cd /root
rm -rf lab-assets
git clone https://github.com/Atnaszurc/tf-200-instruqt.git lab-assets

# Copy Challenge 1 assets to workspace
echo "Copying Challenge 1 assets to workspace..."
cd /root/terraform-workspace
mkdir -p examples
# Copy all module files
cp -r /root/lab-assets/assets/challenge-01/modules ./examples/

# Copy example files
cp /root/lab-assets/assets/challenge-01/main.tf ./examples/
cp /root/lab-assets/assets/challenge-01/outputs.tf ./examples/

# Copy README
cp /root/lab-assets/assets/challenge-01/README.md ./examples/

echo "✓ Setup complete!"
echo ""
echo "Workspace ready at: /root/terraform-workspace"
echo "Example files available:"
echo "  - Under examples/ folder"
echo ""
echo "Follow the challenge instructions to learn module design!"

exit 0


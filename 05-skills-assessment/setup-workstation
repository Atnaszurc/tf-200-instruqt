#!/bin/bash
set -euo pipefail

# Challenge 5: Skills Assessment - Setup Script
# Prepares environment for final assessment

echo "Setting up Challenge 5: Skills Assessment..."

# Create base directory structure
mkdir -p /root/terraform/{modules,config,legacy}

# ============================================================================
# Create Legacy Infrastructure (to be imported)
# ============================================================================
echo "Creating legacy infrastructure for import practice..."

# Create legacy-app-network
cat > /tmp/legacy-app-network.xml << 'EOF'
<network>
  <name>legacy-app-network</name>
  <forward mode='nat'/>
  <bridge name='virbr100' stp='on' delay='0'/>
  <ip address='10.100.0.1' netmask='255.255.255.0'>
    <dhcp>
      <range start='10.100.0.2' end='10.100.0.254'/>
    </dhcp>
  </ip>
</network>
EOF

virsh net-define /tmp/legacy-app-network.xml
virsh net-start legacy-app-network
virsh net-autostart legacy-app-network

echo "✅ Created legacy-app-network"

# Create legacy storage pool for legacy VM
virsh pool-define-as legacy-pool dir - - - - "/var/lib/libvirt/images/legacy"
virsh pool-build legacy-pool
virsh pool-start legacy-pool
virsh pool-autostart legacy-pool

# Create a small disk for legacy VM
qemu-img create -f qcow2 /var/lib/libvirt/images/legacy/legacy-app-server.qcow2 1G

# Create legacy-app-server VM
cat > /tmp/legacy-app-server.xml << 'EOF'
<domain type='kvm'>
  <name>legacy-app-server</name>
  <memory unit='MiB'>512</memory>
  <vcpu>1</vcpu>
  <os>
    <type arch='x86_64'>hvm</type>
    <boot dev='hd'/>
  </os>
  <devices>
    <disk type='file' device='disk'>
      <driver name='qemu' type='qcow2'/>
      <source file='/var/lib/libvirt/images/legacy/legacy-app-server.qcow2'/>
      <target dev='vda' bus='virtio'/>
    </disk>
    <interface type='network'>
      <source network='legacy-app-network'/>
      <model type='virtio'/>
    </interface>
    <console type='pty'/>
  </devices>
</domain>
EOF

virsh define /tmp/legacy-app-server.xml
# Don't start the VM to save resources, just define it

echo "✅ Created legacy-app-server (defined, not started)"

# ============================================================================
# Create Sample YAML Configuration Files
# ============================================================================
echo "Creating sample YAML configuration files..."

cat > /root/terraform/config/dev.yaml << 'EOF'
environment: dev
frontend:
  server_count: 2
  network_cidr: "10.10.0.0/24"
  monitoring_enabled: false
application:
  server_count: 2
  network_cidr: "10.11.0.0/24"
  caching_enabled: false
database:
  server_count: 1
  network_cidr: "10.12.0.0/24"
  backup_enabled: false
  replication_enabled: false
EOF

cat > /root/terraform/config/staging.yaml << 'EOF'
environment: staging
frontend:
  server_count: 2
  network_cidr: "10.20.0.0/24"
  monitoring_enabled: true
application:
  server_count: 3
  network_cidr: "10.21.0.0/24"
  caching_enabled: true
database:
  server_count: 1
  network_cidr: "10.22.0.0/24"
  backup_enabled: true
  replication_enabled: false
EOF

cat > /root/terraform/config/prod.yaml << 'EOF'
environment: prod
frontend:
  server_count: 3
  network_cidr: "10.30.0.0/24"
  monitoring_enabled: true
application:
  server_count: 4
  network_cidr: "10.31.0.0/24"
  caching_enabled: true
database:
  server_count: 2
  network_cidr: "10.32.0.0/24"
  backup_enabled: true
  replication_enabled: true
EOF

echo "✅ Created YAML configuration files"

# ============================================================================
# Create Helper Scripts
# ============================================================================
echo "Creating helper scripts..."

cat > /root/terraform/validate-structure.sh << 'EOF'
#!/bin/bash
# Helper script to validate module structure

echo "=== Validating Module Structure ==="
echo ""

ERRORS=0

# Check for required modules
for module in frontend application database app-stack; do
  if [ -d "modules/$module" ]; then
    echo "✅ Module exists: $module"
    
    # Check for required files
    for file in main.tf variables.tf outputs.tf README.md; do
      if [ -f "modules/$module/$file" ]; then
        echo "  ✅ $file"
      else
        echo "  ❌ Missing: $file"
        ERRORS=$((ERRORS + 1))
      fi
    done
  else
    echo "❌ Module missing: $module"
    ERRORS=$((ERRORS + 1))
  fi
  echo ""
done

# Check for YAML configs
echo "=== Validating YAML Configurations ==="
for env in dev staging prod; do
  if [ -f "config/$env.yaml" ]; then
    echo "✅ Configuration exists: $env.yaml"
  else
    echo "❌ Configuration missing: $env.yaml"
    ERRORS=$((ERRORS + 1))
  fi
done
echo ""

if [ $ERRORS -eq 0 ]; then
  echo "✅ Structure validation passed!"
  exit 0
else
  echo "❌ Structure validation failed with $ERRORS error(s)"
  exit 1
fi
EOF

chmod +x /root/terraform/validate-structure.sh

cat > /root/terraform/test-environment.sh << 'EOF'
#!/bin/bash
# Helper script to test a specific environment

if [ $# -eq 0 ]; then
  echo "Usage: $0 <environment>"
  echo "Example: $0 dev"
  exit 1
fi

ENV=$1

if [ ! -f "config/$ENV.yaml" ]; then
  echo "❌ Configuration file not found: config/$ENV.yaml"
  exit 1
fi

echo "=== Testing Environment: $ENV ==="
echo ""

# Initialize if needed
if [ ! -d ".terraform" ]; then
  echo "Initializing Terraform..."
  terraform init
  echo ""
fi

# Plan with environment variable
echo "Running terraform plan for $ENV..."
TF_VAR_environment=$ENV terraform plan

echo ""
echo "✅ Plan completed for $ENV"
EOF

chmod +x /root/terraform/test-environment.sh

cat > /root/terraform/discover-legacy.sh << 'EOF'
#!/bin/bash
# Helper script to discover legacy infrastructure

echo "=== Legacy Infrastructure Discovery ==="
echo ""

echo "Networks:"
virsh net-list --all | grep legacy

echo ""
echo "VMs:"
virsh list --all | grep legacy

echo ""
echo "Storage Pools:"
virsh pool-list --all | grep legacy

echo ""
echo "=== Legacy Network Details ==="
virsh net-dumpxml legacy-app-network | grep -E "(name|bridge|ip address|range)"

echo ""
echo "=== Legacy VM Details ==="
virsh dumpxml legacy-app-server | grep -E "(name|memory|vcpu|source file|source network)"
EOF

chmod +x /root/terraform/discover-legacy.sh


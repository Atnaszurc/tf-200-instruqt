cat > /root/terraform/variables.tf << 'EOF'
variable "environment" {
  description = "Environment name (dev, staging, prod)"
  type        = string
  default     = "dev"
}

# TODO: Add additional variables as needed
EOF

cat > /root/terraform/outputs.tf << 'EOF'

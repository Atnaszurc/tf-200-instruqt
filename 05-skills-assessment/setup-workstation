EOF

# ============================================================================
# Create Module Template Structure
# ============================================================================
echo "Creating module template structure..."

for module in frontend application database app-stack; do
  mkdir -p /root/terraform/modules/$module
  
  cat > /root/terraform/modules/$module/main.tf << 'EOF'

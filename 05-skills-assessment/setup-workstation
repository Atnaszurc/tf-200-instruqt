done

echo "✅ Created module template structure"

# ============================================================================
# Initialize Terraform
# ============================================================================
cd /root/terraform
terraform init > /dev/null 2>&1

# ============================================================================
# Cleanup temporary files
# ============================================================================
rm -f /tmp/*.xml

echo ""
echo "✅ Challenge 5 setup complete!"
echo ""
echo "Environment includes:"
echo "  - Legacy infrastructure (network + VM) for import practice"
echo "  - YAML configuration files for 3 environments (from GitHub)"
echo "  - Helper scripts for validation and testing"
echo "  - Module template structure"
echo "  - Starter Terraform configuration"
echo ""
echo "Get started with:"
echo "  cd /root/terraform"
echo "  cat README.md"
echo "  ./discover-legacy.sh"
echo ""
echo "Good luck! 🚀"


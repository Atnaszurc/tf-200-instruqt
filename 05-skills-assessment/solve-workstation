#!/bin/bash
set -euo pipefail

# Challenge 5: Skills Assessment - Solve Script
# Provides a complete reference solution using GitHub-hosted assets

echo "==================================================================="
echo "Challenge 5: Skills Assessment - Complete Solution"
echo "==================================================================="
echo ""
echo "Deploying a production-ready, modular infrastructure..."
echo ""

cd /root/terraform

# Clean up any leftover files from previous challenges
echo "🧹 Cleaning workspace..."
rm -rf * .terraform* 2>/dev/null || true
echo "✅ Workspace cleaned"
echo ""

# Clone GitHub repository with assets
echo "📦 Cloning solution assets from GitHub..."
cd /root
rm -rf lab-assets
git clone https://github.com/Atnaszurc/tf-200-instruqt.git lab-assets

# Copy complete solution from assets
echo "📁 Deploying solution files..."
cd /root/terraform
cp -r /root/lab-assets/assets/challenge-05/* .
echo "✅ Solution files deployed"
echo ""

# Create generated directory for outputs
mkdir -p generated

# Display structure
echo "📁 Solution structure:"
tree -L 2 -I '.terraform*' || find . -maxdepth 2 -type d | grep -v '.terraform' | sort
echo ""

# Get UUIDs for legacy resources and update import blocks
echo "🔍 Discovering legacy resource UUIDs..."
NETWORK_UUID=$(virsh net-uuid legacy-app-network)
DOMAIN_UUID=$(virsh domuuid legacy-app-server)

echo "  Network UUID: $NETWORK_UUID"
echo "  Domain UUID: $DOMAIN_UUID"
echo ""

echo "📝 Updating import blocks with UUIDs..."
sed -i "s|id = \"legacy-app-network\"|id = \"$NETWORK_UUID\"|" main.tf
sed -i "s|id = \"legacy-app-server\"|id = \"$DOMAIN_UUID\"|" main.tf
echo "✅ Import blocks updated"
echo ""

# Initialize Terraform
echo "==================================================================="
echo "Initializing Terraform..."
echo "==================================================================="
terraform init
echo ""

# Validate configuration
echo "==================================================================="
echo "Validating configuration..."
echo "==================================================================="
terraform validate
echo ""

# Show plan
echo "==================================================================="
echo "Planning deployment..."
echo "==================================================================="
terraform plan
echo ""

# Apply configuration
echo "==================================================================="
echo "Deploying dev environment..."
echo "==================================================================="
terraform apply -auto-approve
echo ""

# Display outputs
echo "==================================================================="
echo "Deployment Complete! 🎉"
echo "==================================================================="
echo ""
terraform output
echo ""

echo "✅ Challenge 5 solved successfully!"
echo ""
echo "Solution includes:"
echo "  • Frontend Module: Web tier with load balancing"
echo "  • Application Module: Canary deployment pattern"
echo "  • Database Module: Primary/replica with backups"
echo "  • App-Stack Module: Complete composition"
echo ""
echo "All infrastructure deployed and validated!"

# Made with Bob

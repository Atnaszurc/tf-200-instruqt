#!/bin/bash
set -euo pipefail

# Challenge 5: Skills Assessment - Solve Script
# Provides a complete reference solution using GitHub-hosted assets

echo "==================================================================="
echo "Challenge 5: Skills Assessment - Complete Solution"
echo "==================================================================="
echo ""
echo "Deploying a production-ready, modular infrastructure..."
echo ""

cd /root/terraform

# Clean up any leftover files from previous challenges
echo "🧹 Cleaning workspace..."
echo "Current directory: $(pwd)"
echo "Files before cleanup:"
ls -la | head -10
echo ""

# Remove all files and directories (including hidden ones except . and ..)
find . -mindepth 1 -maxdepth 1 ! -name '.' ! -name '..' -exec rm -rf {} + 2>/dev/null || true

echo "Files after cleanup:"
ls -la
echo "✅ Workspace cleaned"
echo ""

# Clone GitHub repository with assets
echo "📦 Cloning solution assets from GitHub..."
cd /root
rm -rf lab-assets
git clone https://github.com/Atnaszurc/tf-200-instruqt.git lab-assets

# Copy complete solution from assets
echo "📁 Deploying solution files..."
cd /root/terraform
cp -r /root/lab-assets/assets/challenge-05/* .
echo "✅ Solution files deployed"
echo ""

# Create generated directory for outputs
mkdir -p generated

# Display structure
echo "📁 Solution structure:"
tree -L 2 -I '.terraform*' || find . -maxdepth 2 -type d | grep -v '.terraform' | sort
echo ""

# Remove import blocks from main.tf (they don't work with libvirt's UUID requirement)
# We'll use CLI imports instead after terraform init
echo "📝 Removing import blocks from main.tf (will use CLI imports)..."
sed -i '/^import {/,/^}/d' main.tf
echo "✅ Import blocks removed"
echo ""

# Ensure legacy resources exist (in case setup script failed)
echo "==================================================================="
echo "Ensuring legacy resources exist..."
echo "==================================================================="

# Create legacy storage pool if it doesn't exist
if ! virsh pool-list --all | grep -q legacy-pool; then
  echo "Creating legacy storage pool..."
  virsh pool-define-as legacy-pool dir - - - - "/var/lib/libvirt/images/legacy"
  virsh pool-build legacy-pool
  virsh pool-start legacy-pool
  virsh pool-autostart legacy-pool
  echo "✅ Legacy storage pool created"
else
  echo "✅ Legacy storage pool already exists"
  # Ensure it's started
  virsh pool-start legacy-pool 2>/dev/null || true
fi

# Create legacy network if it doesn't exist
if ! virsh net-list --all | grep -q legacy-app-network; then
  echo "Creating legacy-app-network..."
  cat > /tmp/legacy-app-network.xml << 'NETEOF'
<network>
  <name>legacy-app-network</name>
  <forward mode='nat'/>
  <bridge name='virbr100' stp='on' delay='0'/>
  <ip address='192.168.100.1' netmask='255.255.255.0'>
    <dhcp>
      <range start='192.168.100.2' end='192.168.100.254'/>
    </dhcp>
  </ip>
</network>
NETEOF
  virsh net-define /tmp/legacy-app-network.xml
  virsh net-start legacy-app-network
  virsh net-autostart legacy-app-network
  echo "✅ Legacy network created"
else
  echo "✅ Legacy network already exists"
  # Ensure it's started
  virsh net-start legacy-app-network 2>/dev/null || true
fi

# Create legacy domain if it doesn't exist
if ! virsh list --all | grep -q legacy-app-server; then
  echo "Creating legacy-app-server domain..."
  
  # Create disk if it doesn't exist
  if [ ! -f /var/lib/libvirt/images/legacy/legacy-app-server.qcow2 ]; then
    qemu-img create -f qcow2 /var/lib/libvirt/images/legacy/legacy-app-server.qcow2 1G
  fi
  
  # Define the domain
  cat > /tmp/legacy-app-server.xml << 'DOMEOF'
<domain type='kvm'>
  <name>legacy-app-server</name>
  <memory unit='MiB'>512</memory>
  <vcpu>1</vcpu>
  <os>
    <type arch='x86_64'>hvm</type>
    <boot dev='hd'/>
  </os>
  <devices>
    <disk type='file' device='disk'>
      <driver name='qemu' type='qcow2'/>
      <source file='/var/lib/libvirt/images/legacy/legacy-app-server.qcow2'/>
      <target dev='vda' bus='virtio'/>
    </disk>
    <interface type='network'>
      <source network='legacy-app-network'/>
      <model type='virtio'/>
    </interface>
    <console type='pty'/>
  </devices>
</domain>
DOMEOF
  virsh define /tmp/legacy-app-server.xml
  echo "✅ Legacy domain created"
else
  echo "✅ Legacy domain already exists"
fi

echo ""

# Initialize Terraform
echo "==================================================================="
echo "Initializing Terraform..."
echo "==================================================================="
terraform init
echo ""

# Import legacy domain using CLI (import blocks don't work with libvirt UUIDs)
# Note: We don't import the legacy network to avoid libvirt provider bug with updating imported networks
echo "==================================================================="
echo "Importing legacy domain..."
echo "==================================================================="
echo "Getting domain UUID from virsh..."
DOMAIN_UUID=$(virsh domuuid legacy-app-server)

echo "  Domain UUID: $DOMAIN_UUID"
echo ""

echo "Importing legacy-app-server..."
terraform import libvirt_domain.legacy "$DOMAIN_UUID"
echo ""

echo "✅ Legacy resources imported successfully"
echo ""

# Validate configuration
echo "==================================================================="
echo "Validating configuration..."
echo "==================================================================="
terraform validate
echo ""

# Show plan
echo "==================================================================="
echo "Planning deployment..."
echo "==================================================================="
terraform plan
echo ""

# Apply configuration
echo "==================================================================="
echo "Deploying dev environment..."
echo "==================================================================="
terraform apply -auto-approve
echo ""

# Display outputs
echo "==================================================================="
echo "Deployment Complete! 🎉"
echo "==================================================================="
echo ""
terraform output
echo ""

echo "✅ Challenge 5 solved successfully!"
echo ""
echo "Solution includes:"
echo "  • Frontend Module: Web tier with load balancing"
echo "  • Application Module: Canary deployment pattern"
echo "  • Database Module: Primary/replica with backups"
echo "  • App-Stack Module: Complete composition"
echo ""
echo "All infrastructure deployed and validated!"

# Made with Bob

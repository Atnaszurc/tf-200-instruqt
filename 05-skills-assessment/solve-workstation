#!/bin/bash
set -e

# Create legacy storage pool if it doesn't exist
if ! virsh pool-list --all | grep -q legacy-pool; then
  echo "Creating legacy storage pool..."
  virsh pool-define-as legacy-pool dir - - - - "/var/lib/libvirt/images/legacy"
  virsh pool-build legacy-pool
  virsh pool-start legacy-pool
  virsh pool-autostart legacy-pool
  echo "✅ Legacy storage pool created"
else
  echo "✅ Legacy storage pool already exists"
  # Ensure it's started
  virsh pool-start legacy-pool 2>/dev/null || true
fi

# Create legacy network if it doesn't exist
if ! virsh net-list --all | grep -q legacy-app-network; then
  echo "Creating legacy-app-network..."
  cat > /tmp/legacy-app-network.xml << 'NETEOF'
<network>
  <name>legacy-app-network</name>
  <forward mode='nat'/>
  <bridge name='virbr100' stp='on' delay='0'/>
  <ip address='192.168.100.1' netmask='255.255.255.0'>
    <dhcp>
      <range start='192.168.100.2' end='192.168.100.254'/>
    </dhcp>
  </ip>
</network>
NETEOF
  virsh net-define /tmp/legacy-app-network.xml
  virsh net-start legacy-app-network
  virsh net-autostart legacy-app-network
  echo "✅ Legacy network created"
else
  echo "✅ Legacy network already exists"
  # Ensure it's started
  virsh net-start legacy-app-network 2>/dev/null || true
fi

# Create legacy domain if it doesn't exist
if ! virsh list --all | grep -q legacy-app-server; then
  echo "Creating legacy-app-server domain..."
  
  # Create disk if it doesn't exist
  if [ ! -f /var/lib/libvirt/images/legacy/legacy-app-server.qcow2 ]; then
    qemu-img create -f qcow2 /var/lib/libvirt/images/legacy/legacy-app-server.qcow2 1G
  fi
  
  # Define the domain
  cat > /tmp/legacy-app-server.xml << 'DOMEOF'
<domain type='kvm'>
  <name>legacy-app-server</name>
  <memory unit='MiB'>512</memory>
  <vcpu>1</vcpu>
  <os>
    <type arch='x86_64'>hvm</type>
    <boot dev='hd'/>
  </os>
  <devices>
    <disk type='file' device='disk'>
      <driver name='qemu' type='qcow2'/>
      <source file='/var/lib/libvirt/images/legacy/legacy-app-server.qcow2'/>
      <target dev='vda' bus='virtio'/>
    </disk>
    <interface type='network'>
      <source network='legacy-app-network'/>
      <model type='virtio'/>
    </interface>
    <console type='pty'/>
  </devices>
</domain>
DOMEOF
  virsh define /tmp/legacy-app-server.xml
  echo "✅ Legacy domain created"
else
  echo "✅ Legacy domain already exists"
fi
# Challenge 5: Skills Assessment - Solve Script
# Copies complete working solution from assets

echo "Creating Challenge 5 solution..."

cd /root/terraform

# Copy complete solution from assets
if [ -d "/root/lab-assets/assets/challenge-05" ]; then
  echo "Copying solution files from assets..."
  cp -r /root/lab-assets/assets/challenge-05/* .
  NETWORK_UUID=$(virsh net-uuid legacy-app-network)
  DOMAIN_UUID=$(virsh domuuid legacy-app-server)
  # Create terraform.tfvars with legacy network UUID
cat > terraform.tfvars << EOF
# Auto-generated by solve script
legacy_network_uuid = "$NETWORK_UUID"
legacy_app_domain_uuid = "$DOMAIN_UUID"
EOF
  echo "✅ Solution files copied"
  echo ""
  echo "Initializing Terraform..."
  terraform init
  
  echo "✅ Terraform initialized"
  echo ""
  echo "Applying configuration..."
  terraform apply -auto-approve
  
  echo "✅ Infrastructure deployed"
  echo ""
  echo "Solution complete! All checks should pass."
else
  echo "❌ Error: Assets not found at /root/lab-assets/assets/challenge-05"
  echo "Please ensure the lab setup completed successfully."
  exit 1
fi


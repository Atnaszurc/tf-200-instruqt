#!/bin/bash
set -euxo pipefail

# Challenge 2 Setup: Advanced Module Patterns
# Clone assets from GitHub and prepare environment

echo "=== Challenge 2: Advanced Module Patterns Setup ==="

# Navigate to workspace
cd /root/terraform-workspace
terraform destroy -auto-approve || true
# Clean any existing content
rm -rf *

# Clone the lab assets repository (if not already cloned)
echo "Cloning lab assets from GitHub..."
cd /root
rm -rf lab-assets
git clone https://github.com/Atnaszurc/tf-200-instruqt.git lab-assets

# Copy Challenge 2 assets to workspace
echo "Copying Challenge 2 assets to workspace..."
cd /root/terraform-workspace
mkdir -p examples

# Copy all files to examples folder
cp -r /root/lab-assets/assets/challenge-02/modules ./examples/
cp /root/lab-assets/assets/challenge-02/main.tf ./examples/
cp /root/lab-assets/assets/challenge-02/README.md ./examples/

# Also copy modules to working directory (needed for terraform init)
cp -r /root/lab-assets/assets/challenge-02/modules ./

echo "✓ Setup complete!"
echo ""
echo "Workspace ready at: /root/terraform-workspace"
echo "Example files available:"
echo "  - Examples folder with examples of advanced module patterns"
echo ""
echo "Follow the challenge instructions to learn advanced module patterns!"

exit 0


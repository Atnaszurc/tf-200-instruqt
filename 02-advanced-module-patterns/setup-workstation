echo "✓ Setup complete!"
echo ""
echo "Workspace ready at: /root/terraform-workspace"
echo "Modules created:"
echo "  - modules/network (Layer 1)"
echo "  - modules/storage (Layer 2)"
echo "  - modules/compute (Layer 2)"
echo "  - modules/app-stack (Layer 3 - Nested)"
echo "  - modules/conditional-vm (Conditional resources)"

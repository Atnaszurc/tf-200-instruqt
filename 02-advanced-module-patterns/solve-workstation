# Advanced For_Each Pattern Examples
# These demonstrate additional for_each techniques

# Example 1: For_each with filtering
locals {
  # Only create VMs with memory >= 1024
  large_vms = {
    for k, v in {
      small-vm = { memory_mb = 512, vcpu_count = 1 }
      large-vm = { memory_mb = 2048, vcpu_count = 2 }
      huge-vm  = { memory_mb = 4096, vcpu_count = 4 }
    } :
    k => v
    if v.memory_mb >= 1024
  }
  # Result: large-vm, huge-vm (small-vm filtered out)
}

# Example 2: For_each with transformation
locals {
  # Transform VM names to include environment prefix
  env_vms = {
    for k, v in {
      web = { memory_mb = 512, vcpu_count = 1 }
      api = { memory_mb = 1024, vcpu_count = 2 }
    } :
    "prod-${k}" => v
  }
  # Result: prod-web, prod-api
}

# Example 3: For_each with nested objects (flattening)
locals {
  vm_groups = {
    web = { count = 2, memory_mb = 2048, vcpu_count = 2 }
    api = { count = 3, memory_mb = 4096, vcpu_count = 4 }
  }
  
  # Flatten groups into individual VMs
  flattened_vms = merge([
    for group_name, group_config in local.vm_groups : {
      for i in range(group_config.count) :
      "${group_name}-${i + 1}" => {
        memory_mb  = group_config.memory_mb
        vcpu_count = group_config.vcpu_count
      }
    }
  ]...)
  # Result: web-1, web-2, api-1, api-2, api-3
}

# Example 4: Conditional for_each
locals {
  enable_optional_vms = false
  
  optional_vms = local.enable_optional_vms ? {
    cache = { memory_mb = 1024, vcpu_count = 1 }
    queue = { memory_mb = 512, vcpu_count = 1 }
  } : {}
  # Result: empty map when disabled
}
EOF


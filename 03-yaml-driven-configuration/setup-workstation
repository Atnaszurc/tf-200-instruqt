#!/bin/bash
set -euxo pipefail

# Challenge 3 Setup: YAML-Driven Configuration
# Clone assets from GitHub and prepare environment

echo "=== Challenge 3: YAML-Driven Configuration Setup ==="

# Navigate to workspace
cd /root/terraform-workspace

# Clean any existing content
rm -rf *

# Clone the lab assets repository (if not already cloned)
echo "Cloning lab assets from GitHub..."
cd /root
rm -rf lab-assets
git clone https://github.com/Atnaszurc/tf-200-instruqt.git lab-assets

# Copy Challenge 3 assets to workspace
echo "Copying Challenge 3 assets to workspace..."
cd /root/terraform-workspace

# Copy all config files
cp -r /root/lab-assets/assets/challenge-03/config ./

# Copy module files
cp -r /root/lab-assets/assets/challenge-03/modules ./

# Copy example files
cp /root/lab-assets/assets/challenge-03/main.tf.example ./
cp /root/lab-assets/assets/challenge-03/infrastructure.tf.example ./
cp /root/lab-assets/assets/challenge-03/environments.tf.example ./

# Copy README
cp /root/lab-assets/assets/challenge-03/README.md ./

echo "✓ Setup complete!"
echo ""
echo "Workspace ready at: /root/terraform-workspace"
echo "Configuration files:"
echo "  - config/networks.yaml"
echo "  - config/infrastructure.yaml"
echo "  - config/environments/dev.yaml"
echo "  - config/environments/staging.yaml"
echo "  - config/environments/prod.yaml"
echo ""
echo "Modules:"
echo "  - modules/yaml-validator"
echo ""
echo "Example files available:"
echo "  - main.tf.example"
echo "  - infrastructure.tf.example"
echo "  - environments.tf.example"
echo ""
echo "Follow the challenge instructions to learn YAML-driven configuration!"

exit 0


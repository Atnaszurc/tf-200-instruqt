check_file_exists() {
  local file=$1
  local description=$2
  
  if [ -f "$file" ]; then
    echo "✅ $description exists"
    return 0
  else
    echo "❌ $description not found"
    ERRORS+=("Missing file: $file")
    VALIDATION_PASSED=false
    return 1
  fi
}

check_dir_exists() {
  local dir=$1
  local description=$2
  
  if [ -d "$dir" ]; then
    echo "✅ $description exists"
    return 0
  else
    echo "❌ $description not found"
    ERRORS+=("Missing directory: $dir")
    VALIDATION_PASSED=false
    return 1
  fi
}


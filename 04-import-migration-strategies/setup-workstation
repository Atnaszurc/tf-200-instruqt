#!/bin/bash
set -euo pipefail

# Challenge 4: Import & Migration Strategies - Setup Script
# This script prepares the environment with existing infrastructure to import

echo "Setting up Challenge 4: Import & Migration Strategies..."

# Create base directory structure
mkdir -p /root/terraform/{import-demo,refactor-demo,handoff-demo,cli-import-demo,bulk-import-demo,migration-demo}

# ============================================================================
# Setup 1: Import Demo - Pre-create networks for import practice
# ============================================================================
echo "Creating existing networks for import demo..."

# Create legacy-network
cat > /tmp/legacy-network.xml << 'EOF'
<network>
  <name>legacy-network</name>
  <forward mode='nat'/>
  <bridge name='virbr10' stp='on' delay='0'/>
  <ip address='10.100.0.1' netmask='255.255.255.0'>
    <dhcp>
      <range start='10.100.0.2' end='10.100.0.254'/>
    </dhcp>
  </ip>
</network>
EOF

virsh net-define /tmp/legacy-network.xml
virsh net-start legacy-network
virsh net-autostart legacy-network

# Create app-network

  </ip>
</network>
EOF

virsh net-define /tmp/db-network.xml
virsh net-start db-network
virsh net-autostart db-network

# Create Terraform configuration for import-demo
cat > /root/terraform/import-demo/main.tf << 'EOF'
terraform {
  required_version = ">= 1.5.0"
  required_providers {
    libvirt = {
      source  = "dmacvicar/libvirt"
      version = "~> 0.7"
    }
  }
}

provider "libvirt" {
  uri = "qemu:///system"
}
EOF


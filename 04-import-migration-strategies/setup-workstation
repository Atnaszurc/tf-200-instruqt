# Create network discovery script
cat > /root/terraform/discover-networks.sh << 'EOF'
#!/bin/bash
# Helper script to discover existing networks

echo "=== Existing Libvirt Networks ==="
echo ""
virsh net-list --all

echo ""
echo "=== Network Details ==="
for net in $(virsh net-list --name); do
  if [ ! -z "$net" ]; then
    echo ""
    echo "Network: $net"
    virsh net-dumpxml "$net" | grep -E "(name|bridge|ip address|range)"
  fi
done
EOF

chmod +x /root/terraform/discover-networks.sh

# Create state backup script
cat > /root/terraform/backup-state.sh << 'EOF'
#!/bin/bash
# Helper script to backup Terraform state

if [ ! -f terraform.tfstate ]; then
  echo "No terraform.tfstate file found in current directory"
  exit 1
fi

BACKUP_FILE="backup-$(date +%Y%m%d-%H%M%S).tfstate"
terraform state pull > "$BACKUP_FILE"

echo "State backed up to: $BACKUP_FILE"
ls -lh "$BACKUP_FILE"
EOF

chmod +x /root/terraform/backup-state.sh

# Create validation script
cat > /root/terraform/validate-import.sh << 'EOF'
#!/bin/bash

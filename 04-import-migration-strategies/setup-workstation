#!/bin/bash
set -euo pipefail

# Challenge 4: Import & Migration Strategies - Setup Script
# This script prepares the environment with existing infrastructure to import

echo "Setting up Challenge 4: Import & Migration Strategies..."

# Clone the lab assets repository first
echo "Cloning lab assets from GitHub..."
cd /root
rm -rf lab-assets
git clone https://github.com/Atnaszurc/tf-200-instruqt.git lab-assets

# Create base directory structure
mkdir -p /root/terraform/{import-demo,refactor-demo,handoff-demo,cli-import-demo,bulk-import-demo,migration-demo}

# Copy example files from GitHub to terraform workspace
echo "Copying example files from GitHub..."
cp /root/lab-assets/assets/challenge-04/*.tf /root/terraform/ 2>/dev/null || true
cp /root/lab-assets/assets/challenge-04/*.sh /root/terraform/ 2>/dev/null || true
cp /root/lab-assets/assets/challenge-04/*.md /root/terraform/ 2>/dev/null || true

# Make scripts executable
chmod +x /root/terraform/*.sh 2>/dev/null || true

# ============================================================================
# Setup 1: Import Demo - Pre-create networks for import practice
# ============================================================================
echo "Creating existing networks for import demo..."

# Create legacy-network
cat > /tmp/legacy-network.xml << 'EOF'
<network>
  <name>legacy-network</name>
  <forward mode='nat'/>
  <bridge name='virbr10' stp='on' delay='0'/>
  <ip address='10.100.0.1' netmask='255.255.255.0'>
    <dhcp>
      <range start='10.100.0.2' end='10.100.0.254'/>
    </dhcp>
  </ip>
</network>
EOF

virsh net-define /tmp/legacy-network.xml
virsh net-start legacy-network
virsh net-autostart legacy-network

# Create app-network
cat > /tmp/app-network.xml << 'EOF'
<network>
  <name>app-network</name>
  <forward mode='nat'/>
  <bridge name='virbr11' stp='on' delay='0'/>
  <ip address='10.101.0.1' netmask='255.255.255.0'>
    <dhcp>
      <range start='10.101.0.2' end='10.101.0.254'/>
    </dhcp>
  </ip>
</network>
EOF

virsh net-define /tmp/app-network.xml
virsh net-start app-network
virsh net-autostart app-network

# Create db-network
cat > /tmp/db-network.xml << 'EOF'
<network>
  <name>db-network</name>
  <forward mode='nat'/>
  <bridge name='virbr12' stp='on' delay='0'/>
  <ip address='10.102.0.1' netmask='255.255.255.0'>
    <dhcp>
      <range start='10.102.0.2' end='10.102.0.254'/>
    </dhcp>
  </ip>
</network>
EOF

virsh net-define /tmp/db-network.xml
virsh net-start db-network
virsh net-autostart db-network

# Create Terraform configuration for import-demo
cat > /root/terraform/import-demo/main.tf << 'EOF'
terraform {
  required_version = ">= 1.5.0"
  required_providers {
    libvirt = {
      source  = "dmacvicar/libvirt"
      version = "~> 0.9"
    }
  }
}

provider "libvirt" {
  uri = "qemu:///system"
}
EOF

# ============================================================================
# Setup 2: Refactor Demo - Create initial state for refactoring
# ============================================================================
echo "Setting up refactor demo environment..."

cat > /root/terraform/refactor-demo/main.tf << 'EOF'
terraform {
  required_version = ">= 1.5.0"
  required_providers {
    libvirt = {
      source  = "dmacvicar/libvirt"
      version = "~> 0.9"
    }
  }
}

provider "libvirt" {
  uri = "qemu:///system"
}

# Initial resources with poor naming
resource "libvirt_network" "legacy" {
  name      = "legacy-network"
  autostart = true
  
  ips = [
    {
      address = "10.100.0.1"
      prefix  = 24
      dhcp = {
        ranges = [{
          start = "10.100.0.2"
          end   = "10.100.0.254"
        }]
      }
    }
  ]
  
  forward = {
    mode = "nat"
  }
  
  dns = {
    enabled = true
  }
}

resource "libvirt_network" "app" {
  name      = "app-network"
  autostart = true
  
  ips = [
    {
      address = "10.101.0.1"
      prefix  = 24
      dhcp = {
        ranges = [{
          start = "10.101.0.2"
          end   = "10.101.0.254"
        }]
      }
    }
  ]
  
  forward = {
    mode = "nat"
  }
  
  dns = {
    enabled = true
  }
}

resource "libvirt_network" "db" {
  name      = "db-network"
  autostart = true
  
  ips = [
    {
      address = "10.102.0.1"
      prefix  = 24
      dhcp = {
        ranges = [{
          start = "10.102.0.2"
          end   = "10.102.0.254"
        }]
      }
    }
  ]
  
  forward = {
    mode = "nat"
  }
  
  dns = {
    enabled = true
  }
}
EOF

# Initialize and apply to create initial state
cd /root/terraform/refactor-demo
terraform init > /dev/null 2>&1
terraform apply -auto-approve > /dev/null 2>&1

# ============================================================================
# Setup 3: Handoff Demo - Prepare for removed blocks practice
# ============================================================================
echo "Setting up handoff demo environment..."

cat > /root/terraform/handoff-demo/main.tf << 'EOF'
terraform {
  required_version = ">= 1.7.0"
  required_providers {
    libvirt = {
      source  = "dmacvicar/libvirt"
      version = "~> 0.9"
    }
  }
}

provider "libvirt" {
  uri = "qemu:///system"
}

resource "libvirt_network" "production" {
  name      = "legacy-network"
  autostart = true
  
  ips = [
    {
      address = "10.100.0.1"
      prefix  = 24
      dhcp = {
        ranges = [{
          start = "10.100.0.2"
          end   = "10.100.0.254"
        }]
      }
    }
  ]
  
  forward = {
    mode = "nat"
  }
  
  dns = {
    enabled = true
  }
}

resource "libvirt_network" "application" {
  name      = "app-network"
  autostart = true
  
  ips = [
    {
      address = "10.101.0.1"
      prefix  = 24
      dhcp = {
        ranges = [{
          start = "10.101.0.2"
          end   = "10.101.0.254"
        }]
      }
    }
  ]
  
  forward = {
    mode = "nat"
  }
  
  dns = {
    enabled = true
  }
}

resource "libvirt_network" "database" {
  name      = "db-network"
  autostart = true
  
  ips = [
    {
      address = "10.102.0.1"
      prefix  = 24
      dhcp = {
        ranges = [{
          start = "10.102.0.2"
          end   = "10.102.0.254"
        }]
      }
    }
  ]
  
  forward = {
    mode = "nat"
  }
  
  dns = {
    enabled = true
  }
}
EOF

# Initialize and import existing networks into state
cd /root/terraform/handoff-demo
terraform init > /dev/null 2>&1

# Import the existing networks (they were created by virsh earlier)
terraform import libvirt_network.production legacy-network > /dev/null 2>&1 || true
terraform import libvirt_network.application app-network > /dev/null 2>&1 || true
terraform import libvirt_network.database db-network > /dev/null 2>&1 || true

# ============================================================================
# Setup 4: CLI Import Demo - Create network for CLI import practice
# ============================================================================
echo "Setting up CLI import demo environment..."

# Create cli-import-network
cat > /tmp/cli-import-network.xml << 'EOF'
<network>
  <name>cli-import-network</name>
  <forward mode='nat'/>
  <bridge name='virbr20' stp='on' delay='0'/>
  <ip address='10.200.0.1' netmask='255.255.255.0'>
    <dhcp>
      <range start='10.200.0.2' end='10.200.0.254'/>
    </dhcp>
  </ip>
</network>
EOF

virsh net-define /tmp/cli-import-network.xml
virsh net-start cli-import-network
virsh net-autostart cli-import-network

cat > /root/terraform/cli-import-demo/main.tf << 'EOF'
terraform {
  required_version = ">= 1.5.0"
  required_providers {
    libvirt = {
      source  = "dmacvicar/libvirt"
      version = "~> 0.9"
    }
  }
}

provider "libvirt" {
  uri = "qemu:///system"
}
EOF

# ============================================================================
# Setup 5: Bulk Import Demo - Create multiple networks
# ============================================================================
echo "Setting up bulk import demo environment..."

# Create tier1-network
cat > /tmp/tier1-network.xml << 'EOF'
<network>
  <name>tier1-network</name>
  <forward mode='nat'/>
  <bridge name='virbr30' stp='on' delay='0'/>
  <ip address='10.10.0.1' netmask='255.255.255.0'>
    <dhcp>
      <range start='10.10.0.2' end='10.10.0.254'/>
    </dhcp>
  </ip>
</network>
EOF

virsh net-define /tmp/tier1-network.xml
virsh net-start tier1-network
virsh net-autostart tier1-network

# Create tier2-network
cat > /tmp/tier2-network.xml << 'EOF'
<network>
  <name>tier2-network</name>
  <forward mode='nat'/>
  <bridge name='virbr31' stp='on' delay='0'/>
  <ip address='10.20.0.1' netmask='255.255.255.0'>
    <dhcp>
      <range start='10.20.0.2' end='10.20.0.254'/>
    </dhcp>
  </ip>
</network>
EOF

virsh net-define /tmp/tier2-network.xml
virsh net-start tier2-network
virsh net-autostart tier2-network

# Create tier3-network
cat > /tmp/tier3-network.xml << 'EOF'
<network>
  <name>tier3-network</name>
  <forward mode='nat'/>
  <bridge name='virbr32' stp='on' delay='0'/>
  <ip address='10.30.0.1' netmask='255.255.255.0'>
    <dhcp>
      <range start='10.30.0.2' end='10.30.0.254'/>
    </dhcp>
  </ip>
</network>
EOF

virsh net-define /tmp/tier3-network.xml
virsh net-start tier3-network
virsh net-autostart tier3-network

cat > /root/terraform/bulk-import-demo/main.tf << 'EOF'
terraform {
  required_version = ">= 1.5.0"
  required_providers {
    libvirt = {
      source  = "dmacvicar/libvirt"
      version = "~> 0.9"
    }
  }
}

provider "libvirt" {
  uri = "qemu:///system"
}
EOF

# ============================================================================
# Setup 6: Migration Demo - Complete migration scenario
# ============================================================================
echo "Setting up migration demo environment..."

# Create legacy networks for migration
cat > /tmp/legacy-net-1.xml << 'EOF'
<network>
  <name>legacy-net-1</name>
  <forward mode='nat'/>
  <bridge name='virbr40' stp='on' delay='0'/>
  <ip address='10.50.0.1' netmask='255.255.255.0'>
    <dhcp>
      <range start='10.50.0.2' end='10.50.0.254'/>
    </dhcp>
  </ip>
</network>
EOF

virsh net-define /tmp/legacy-net-1.xml
virsh net-start legacy-net-1
virsh net-autostart legacy-net-1

cat > /tmp/legacy-net-2.xml << 'EOF'
<network>
  <name>legacy-net-2</name>
  <forward mode='nat'/>
  <bridge name='virbr41' stp='on' delay='0'/>
  <ip address='10.51.0.1' netmask='255.255.255.0'>
    <dhcp>
      <range start='10.51.0.2' end='10.51.0.254'/>
    </dhcp>
  </ip>
</network>
EOF

virsh net-define /tmp/legacy-net-2.xml
virsh net-start legacy-net-2
virsh net-autostart legacy-net-2

cat > /tmp/legacy-net-3.xml << 'EOF'
<network>
  <name>legacy-net-3</name>
  <forward mode='nat'/>
  <bridge name='virbr42' stp='on' delay='0'/>
  <ip address='10.52.0.1' netmask='255.255.255.0'>
    <dhcp>
      <range start='10.52.0.2' end='10.52.0.254'/>
    </dhcp>
  </ip>
</network>
EOF

virsh net-define /tmp/legacy-net-3.xml
virsh net-start legacy-net-3
virsh net-autostart legacy-net-3

cat > /root/terraform/migration-demo/main.tf << 'EOF'
terraform {
  required_version = ">= 1.7.0"
  required_providers {
    libvirt = {
      source  = "dmacvicar/libvirt"
      version = "~> 0.9"
    }
  }
}

provider "libvirt" {
  uri = "qemu:///system"
}
EOF

# ============================================================================
# Initialize Terraform in directories that need it
# ============================================================================
echo "Initializing Terraform directories..."

for dir in import-demo cli-import-demo bulk-import-demo migration-demo; do
  cd /root/terraform/$dir
  terraform init > /dev/null 2>&1
done

# ============================================================================
# Set permissions
# ============================================================================
chmod -R 755 /root/terraform

# ============================================================================
# Cleanup temporary files
# ============================================================================
rm -f /tmp/*.xml

echo "✅ Challenge 4 setup complete!"
echo ""
echo "Environment includes:"
echo "  - 10 pre-created networks for import practice"
echo "  - 6 demo directories with different scenarios"
echo "  - Example files from GitHub (import/moved/removed examples)"
echo "  - Helper scripts for common tasks"
echo ""
echo "Start with: cd /root/terraform && ls -la"

# Made with Bob

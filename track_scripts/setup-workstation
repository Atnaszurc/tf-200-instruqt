#!/bin/bash
set -euxo pipefail

# Track-level setup script for TF-200 Modules Lab
# This runs once when the track starts

echo "=== TF-200 Terraform Modules & Patterns Lab Setup ==="
echo "Setting up your learning environment..."

# Update system
export DEBIAN_FRONTEND=noninteractive
apt-get update -y

# Install prerequisites
echo "Installing prerequisites..."
apt-get install -y \
    wget \
    curl \
    unzip \
    gnupg \
    software-properties-common \
    apt-transport-https \
    ca-certificates \
    lsb-release

# Install Terraform (latest stable)
echo "Installing Terraform..."
wget -O- https://apt.releases.hashicorp.com/gpg | gpg --dearmor -o /usr/share/keyrings/hashicorp-archive-keyring.gpg
echo "deb [signed-by=/usr/share/keyrings/hashicorp-archive-keyring.gpg] https://apt.releases.hashicorp.com $(lsb_release -cs) main" | tee /etc/apt/sources.list.d/hashicorp.list
apt-get update -y

# Try APT installation first, fallback to direct download if it fails
# (HashiCorp APT repo may not support newer Ubuntu versions immediately)
if ! apt-get install -y terraform; then
    echo "⚠ APT installation failed, using direct download fallback..."
    TERRAFORM_VERSION="1.15.3"
    wget -q "https://releases.hashicorp.com/terraform/${TERRAFORM_VERSION}/terraform_${TERRAFORM_VERSION}_linux_amd64.zip"
    unzip -q "terraform_${TERRAFORM_VERSION}_linux_amd64.zip"
    mv terraform /usr/local/bin/
    chmod +x /usr/local/bin/terraform
    rm "terraform_${TERRAFORM_VERSION}_linux_amd64.zip"
    echo "✓ Terraform ${TERRAFORM_VERSION} installed via direct download"
fi

# Verify Terraform installation
terraform version

# Install Libvirt and QEMU for nested virtualization
echo "Installing Libvirt and QEMU..."
apt-get install -y \
    qemu-kvm \
    libvirt-daemon-system \
    libvirt-clients \
    bridge-utils \
    virtinst \
    virt-manager \
    cpu-checker

# Enable and start libvirt
systemctl enable libvirtd
systemctl start libvirtd

# Disable AppArmor for libvirt (ephemeral lab environment)
echo "Disabling AppArmor for libvirt..."
if command -v aa-status &> /dev/null; then
    # Disable libvirt profiles
    for profile in /etc/apparmor.d/libvirt/libvirt-* /etc/apparmor.d/usr.sbin.libvirtd; do
        if [ -f "$profile" ]; then
            ln -sf "$profile" /etc/apparmor.d/disable/ 2>/dev/null || true
        fi
    done
    apparmor_parser -R /etc/apparmor.d/usr.sbin.libvirtd 2>/dev/null || true
    systemctl reload apparmor 2>/dev/null || true
    echo "✓ AppArmor disabled for libvirt"
else
    echo "✓ AppArmor not present"
fi

# Verify nested virtualization support
if kvm-ok; then
    echo "✓ KVM/nested virtualization is supported"
else
    echo "⚠ Warning: KVM may not be fully supported"
fi

# Add default user to libvirt group
usermod -aG libvirt $(whoami) || true

# Install Terraform Libvirt provider dependencies
echo "Installing Libvirt provider dependencies..."
apt-get install -y \
    libvirt-dev \
    pkg-config

# Create workspace directory
mkdir -p /root/terraform-workspace
cd /root/terraform-workspace

# Set up default libvirt network
virsh net-list --all | grep -q default || virsh net-define /usr/share/libvirt/networks/default.xml
virsh net-start default 2>/dev/null || true
# Create default storage pool if it doesn't exist
echo "Setting up default storage pool..."
if ! virsh pool-list --all | grep -q "default"; then
    virsh pool-define-as default dir - - - - "/var/lib/libvirt/images"
    virsh pool-build default
    virsh pool-start default
    virsh pool-autostart default
    echo "✓ Default storage pool created"
else
    virsh pool-start default 2>/dev/null || true
    virsh pool-autostart default
    echo "✓ Default storage pool already exists"
fi

virsh net-autostart default

# Install helpful tools
echo "Installing additional tools..."
apt-get install -y \
    vim \
    nano \
    jq \
    tree \
    git \
    yamllint

# Set bash as default shell for root user
echo "Setting bash as default shell..."
chsh -s /bin/bash root

# Configure bash completion for Terraform
terraform -install-autocomplete 2>/dev/null || true

# Ensure .bashrc is sourced for interactive shells
if ! grep -q "source ~/.bashrc" /root/.bash_profile 2>/dev/null; then
    echo "source ~/.bashrc" >> /root/.bash_profile
fi

# Create welcome message
cat > /etc/motd << 'EOF'
╔══════════════════════════════════════════════════════════════╗
║                                                              ║
║   🚀 TF-200: Terraform Modules & Patterns Lab               ║
║                                                              ║
║   Welcome! Your environment is ready to go.                 ║
║                                                              ║
║   📚 What's Included:                                        ║
║   • Terraform (latest stable, 1.15+)                        ║
║   • Libvirt/QEMU (nested virtualization enabled)            ║
║   • Code editor with syntax highlighting                    ║
║   • All example code pre-populated                          ║
║   • YAML validation tools                                   ║
║                                                              ║
║   💡 Prerequisites:                                          ║
║   • TF-100 completion (or equivalent knowledge)             ║
║   • Comfortable with Terraform basics                       ║
║   • Understanding of variables, loops, state                ║
║                                                              ║
║   🎯 What You'll Master:                                     ║
║   • Professional module design                              ║
║   • Advanced deployment patterns                            ║
║   • YAML-driven infrastructure                              ║
║   • Import and migration strategies                         ║
║                                                              ║
║   ⏱️  Time: ~6 hours | 9-hour timeout                       ║
║   🔄 Skip enabled: Restart at any challenge                 ║
║                                                              ║
║   Ready to build enterprise-grade Terraform? Let's go! 🎯   ║
║                                                              ║
╚══════════════════════════════════════════════════════════════╝
EOF

# Display versions
echo ""
echo "=== Environment Ready ==="
echo "Terraform version: $(terraform version -json | jq -r '.terraform_version')"
echo "Libvirt version: $(virsh version | head -n1)"
echo "QEMU version: $(qemu-system-x86_64 --version | head -n1)"
echo ""
echo "✓ Setup complete! Your learning environment is ready."
echo ""

# Set working directory
cd /root/terraform-workspace

exit 0

